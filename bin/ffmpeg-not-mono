#!/usr/bin/env bash


# all of these stem from https://www.shellcheck.net/wiki/
set -o pipefail  # propagate errors
set -u  # exit on undefined
set -e  # exit on non-zero return value
#set -f  # disable globbing/filename expansion
shopt -s failglob  # error on unexpaned globs
shopt -s inherit_errexit  # Bash disables set -e in command substitution by default; reverse this behavior


# set -x
# cleanup () { set +x; }
# trap cleanup EXIT

_is_not_mono() {
  # this function returns nothing if the file is mono
  # otherwise the absolute path to the file is returned
  
  local mds=()
  local count=0
  while read -r line; do 
  if [ $count -ge 2 ]; then
    break
  fi

  mds+=("$line")
  ((count=count+1))
  # ffmpeg command taken from https://www.perplexity.ai/search/stereo-m4a-file-to-mono-m4a-ff-XCimxhKzQmWVA66PjrGnBA#8
  done < <(ffmpeg -loglevel error -i "$1" \
               -filter_complex "[0:a]channelsplit=channel_layout=stereo[left][right]" \
               -map "[left]"  -f md5 - \
               -map "[right]" -f md5 - </dev/null)

  if [ "${#mds[@]}" -ne 2 ]; then
    # not 2 chksums
    realpath "$1"
  elif [ "${mds[0]}" != "${mds[1]}" ]; then
    # chksum mismatch
    realpath "$1"
  fi
}

_help() {
cat <<EOF
USAGE: $(basename $0) <FILE>
USAGE: $(basename $0) <DIRs for find>

EOF
}

if [ $# -eq 0 ]; then
  _help
  exit
fi

if [ -d "$1" ]; then
  while read -r line; do
    _is_not_mono "$line"
  done < <(find "$@" -iregex '.*\.\(m4a\|mp3\)' )
else
  _is_not_mono "$1"
fi


